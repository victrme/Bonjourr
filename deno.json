{
	"tasks": {
		"build": "deno ./tasks/build.ts",
		"edge": "deno ./tasks/build.ts edge dev",
		"chrome": "deno ./tasks/build.ts chrome dev",
		"firefox": "deno ./tasks/build.ts firefox dev",
		"safari": "deno ./tasks/build.ts safari dev",
		"online": "deno ./tasks/build.ts online dev",
		"docker": "deno ./tasks/build.ts online prod",
		"lint": "npx prettier --check .",
		"format": "npx prettier ./_locales/**/translations.json --write --log-level silent",
		"translate": "node ./tasks/translate.ts translate && pnpm format"
	},
	"imports": {
		"@victr/deepmerge": "npm:@victr/deepmerge@^1.3.2",
		"clickdown": "npm:clickdown@^1.2.2",
		"idb-keyval": "npm:idb-keyval@^6.2.1",
		"pocket-editor": "npm:pocket-editor@^2.4.0",
		"prism-code-editor": "npm:prism-code-editor@3.4.0",
		"esbuild": "npm:esbuild@^0.24.0",
		"web-ext-types": "npm:web-ext-types@^3.2.1",
		"@types/chrome": "npm:@types/chrome@^0.0.283",
		"user-agent-data-types": "npm:user-agent-data-types@^0.4.2"
	},
	"fmt": {
		"indentWidth": 4,
		"useTabs": true,
		"semiColons": false,
		"singleQuote": true,
		"lineWidth": 128
	},
	"compilerOptions": {
		"types": [
			"user-agent-data-types",
			"web-ext-types",
			"chrome"
		],
		"strict": true,
		"allowJs": true
	},
	"unstable": [
		"sloppy-imports"
	]
}